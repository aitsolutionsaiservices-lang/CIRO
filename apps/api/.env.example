# Copy to .env and fill in. DO NOT commit .env.
GEMINI_API_KEY=your-google-api-key-here
# gemini-2.5-flash is free-tier accessible. Upgrade to -pro on a billed project for better reasoning.
GEMINI_MODEL=gemini-2.5-flash

# CORS — "*" allows everything (dev convenience). For production set an
# explicit comma-separated list, e.g.:
#   CIRO_CORS_ORIGINS=https://dashboard.example.com,https://app.example.com
CIRO_CORS_ORIGINS=*
